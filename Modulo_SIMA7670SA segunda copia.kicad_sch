	(text "PC13 ocupado con USER-LED.\nPA9 (USART1_TX)	\nPA10 (USART1_RX)	\nPA4 PWRKEY\nPA5 SLEEP (DTR)\nPA1 WDI (Watchdog Input)\nNRST Reset Watchdog \nPA11 (D-) y PA12 (D+)\nPA9 USB_VBUS (Detección de 5V, opcional)\nPA0 usado por KEY\nPB2 con pullDown de 10K\nPA13 SWDIO\nPA14 SWCLK\nPA4 F_CS\nPA5 SCK\nPA7 MOSI\nPB4 MISO\nCable USSB-C to USB-micro-B (50092319)\nST-LINK V2 (20070241)\nBlack Pill (60069228)"
		(exclude_from_sim no)
		(at 192.278 86.614 0)
